# Baserow API Token
# Get this from: baserow.io → Settings → API Tokens → Create Token
BASEROW_TOKEN=your_token_here

# Baserow Table IDs
# Get these from the URL when viewing each table in Baserow:
# e.g. baserow.io/database/123/table/456  →  table ID is 456
BASEROW_CLIENTS_TABLE_ID=your_clients_table_id
BASEROW_PROJECTS_TABLE_ID=your_projects_table_id
BASEROW_SESSIONS_TABLE_ID=your_sessions_table_id
